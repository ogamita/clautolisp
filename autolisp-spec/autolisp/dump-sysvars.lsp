(defun dump-sysvars-names ( )
  "Return the sorted list of known system-variable names."
  *dump-sysvars-names*)

(defun dump-sysvars ( filename / f count name )
  "Write every known system variable and its current value to
FILENAME, one variable per line, as

    \"NAME\" VALUE

using PRIN1 for both fields. Return the number of variables written,
or nil if FILENAME could not be opened for output."
  (setq f (open filename "w"))
  (if (null f)
      (progn
        (princ "dump-sysvars: cannot open file for writing: ")
        (princ filename)
        (princ "\n")
        nil)
      (progn
        (setq count 0)
        (foreach name *dump-sysvars-names*
          (prin1 name f)              ; "NAME" (quoted, via prin1)
          (princ " " f)
          (prin1 (getvar name) f)     ; VALUE  (quoted if a string)
          (princ "\n" f)
          (setq count (1+ count)))
        (close f)
        count)))

(princ)
