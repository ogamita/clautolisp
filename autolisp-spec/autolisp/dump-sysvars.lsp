;;;; dump-sysvars.lsp -- dump every system variable and its current
;;;; value to a file, one variable per line.
;;;;
;;;; Companion utility to alref.lsp. Loadable into any conforming
;;;; AutoLISP implementation (AutoCAD, BricsCAD, clautolisp).
;;;;
;;;; Entry point:
;;;;
;;;;   (dump-sysvars "sysvars.txt")
;;;;       Write one line per system variable to FILENAME, in the
;;;;       form
;;;;
;;;;           "NAME" VALUE
;;;;
;;;;       where both NAME and VALUE are emitted with PRIN1 (not
;;;;       PRINC), so string values keep their surrounding quotes and
;;;;       the file is re-readable. Returns the number of variables
;;;;       written, or nil if FILENAME could not be opened.
;;;;
;;;;   (dump-sysvars-names)
;;;;       Return the list of system-variable names this utility
;;;;       knows about (already sorted lexicographically).
;;;;
;;;; Why an embedded name list?
;;;;
;;;; Stock AutoLISP offers no primitive that enumerates the system
;;;; variables: (getvar name) reads one variable by name, but there is
;;;; no (getvars) or apropos-style listing. So, as specified, the
;;;; name list is taken from the documented inventory in
;;;; autolisp-spec/documentation/system-variables-inventory.sexp and
;;;; embedded here, sorted lexicographically (ASCII / C collation) by
;;;; variable name.
;;;;
;;;; (getvar "NAME") returns nil for a variable the running host does
;;;; not implement; such variables still produce a line, with a nil
;;;; value.
;;;;
;;;; Portable across AutoCAD / BricsCAD / clautolisp: uses only the
;;;; strict-subset primitives (open, close, prin1, princ, terpri,
;;;; getvar, foreach, basic list ops). No vl-string-*, no
;;;; host-specific extensions.

;; Library version. Format is MAJOR.MINOR.DEVELOP, matching the
;; clautolisp / alref convention. Bump the DEVELOP counter on every
;; change that touches this file's behaviour.
(setq *dump-sysvars-version* "1.0.0")

(defun dump-sysvars-version ( )
  "Return the dump-sysvars.lsp library version as a string."
  *dump-sysvars-version*)

