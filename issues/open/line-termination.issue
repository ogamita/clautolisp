17:30[pjb@thalassa org.xquartz:0 clautolisp 83Gi]$ cat ~/check-vars
#!/bin/bash

driver=clautolisp

for arg ; do
    case "$arg" in
    (clautolisp)  driver=clautolisp ;;
    (alfe)        driver=alfe ;;
    (*)
        printf "Error; usage: %s [clautolisp|alfe]\n" "$0"
        exit 1
        ;;
    esac
done

(
    export LC_ALL=en_US.UTF-8
    export LANG=fr_FR.ISO-8859-1
    export LC_CTYPE=de_GE.WINDOWS-1252
    echo === LC_ALL=${LC_ALL:-undefined} LANG=${LANG:-undefined} LC_CTYPE=${LC_CTYPE:-undefined} -E koi-8 -e iso-8859-15
    "$driver" \
        -norc \
        -E KOI-8 \
        -e ISO-8859-15 \
        -x '(print (list (quote *autolisp-version*) *autolisp-version*))' \
        -x '(print (list (quote *AUTOLISP-FILE-ENCODING*) *AUTOLISP-FILE-ENCODING*))' \
        -x '(print (list (quote *AUTOLISP-TERMINAL-ENCODING*) *AUTOLISP-TERMINAL-ENCODING*))' \
        -x '(terpri)'
    for var in LC_ALL LANG LC_CTYPE ; do
        echo === LC_ALL=${LC_ALL:-undefined} LANG=${LANG:-undefined} LC_CTYPE=${LC_CTYPE:-undefined} no -e -E
        "$driver" \
            -norc \
            -x '(print (list (quote *autolisp-version*) *autolisp-version*))' \
            -x '(print (list (quote *AUTOLISP-FILE-ENCODING*) *AUTOLISP-FILE-ENCODING*))' \
            -x '(print (list (quote *AUTOLISP-TERMINAL-ENCODING*) *AUTOLISP-TERMINAL-ENCODING*))' \
            -x '(terpri)'
        unset $var
    done
)


for line_termination in '' -mac -dos -unix ; do
        echo === -e UTF-8$line_termination
        "$driver" \
            -norc \
            -e UTF-8$line_termination \
            -E UTF-8 \zss
            -x '(print (list (quote *autolisp-version*) *autolisp-version*))' \
            -x '(print (list (quote *AUTOLISP-FILE-ENCODING*) *AUTOLISP-FILE-ENCODING*))' \
            -x '(print (list (quote *AUTOLISP-TERMINAL-ENCODING*) *AUTOLISP-TERMINAL-ENCODING*))' \
            -x '(terpri)'
        unset $var
done
