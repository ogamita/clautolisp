16:53[pjb@thalassa org.xquartz:0 open 84Gi]$ cat ~/check-vars
#!/bin/bash

driver=clautolisp

for arg ; do
    case "$arg" in
    (clautolisp)  driver=clautolisp ;;
    (alfe)        driver=alfe ;;
    (*)
        printf "Error; usage: %s [clautolisp|alfe]\n" "$0"
        exit 1
        ;;
    esac
done

"$driver" \
    -norc -e uft-8 \
    -x '(print (list (quote *autolisp-version*) *autolisp-version*))' \
    -x '(print (list (quote *AUTOLISP-FILE-ENCODING*) *AUTOLISP-FILE-ENCODING*))' \
    -x '(print (list (quote *AUTOLISP-TERMINAL-ENCODING*) *AUTOLISP-TERMINAL-ENCODING*))' \
    -x '(terpri)' \
    --load "/opt/local/share/autolisp/site-lisp/autolisp-spec/alref.lsp" \
    -x '(alref-apropos "AUTOLISP-")' \
    -q

